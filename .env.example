SIMULATION_MODE=true
LOG_LEVEL=info

COINBASE_API_KEY=
COINBASE_API_SECRET=
PRODUCT_ID=BTC-USD

# Quote width around BBO (basis points)
SPREAD_BPS=8
ORDER_SIZE=0.001
QUOTE_REFRESH_MS=1500

# Inventory skew — shift quotes when base inventory drifts (BTC units)
TARGET_BASE_INVENTORY=0
MAX_BASE_INVENTORY=0.01
SKEW_BPS_PER_UNIT=50

# Circuit breaker
MAX_DAILY_LOSS_USD=200
CIRCUIT_BREAKER_COOLDOWN_MS=300000

# Optional Redis (mm-state + last quote cache)
# REDIS_URL=redis://localhost:6379
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_ENABLED=true
# REDIS_KEY_PREFIX=cb-mm:
# REDIS_CACHE_TTL_SEC=86400
